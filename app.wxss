page {
  min-height: 100vh;
  background: #f5f7fb;
  color: #1f2937;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.scroll-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-area {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 20rpx;
}

.badge {
  display: inline-block;
  font-size: 22rpx;
  line-height: 1;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #2563eb;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.muted {
  color: #6b7280;
  font-size: 24rpx;
}

.primary-btn {
  background: linear-gradient(120deg, #3b82f6, #2563eb);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 26rpx;
  padding: 14rpx 24rpx;
}

.progress {
  width: 220rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(120deg, #22c55e, #16a34a);
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.tab-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx 14rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.05);
}

.tab-title {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.kpi-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.kpi-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
}

.kpi-label {
  font-size: 22rpx;
  color: #6b7280;
}

.list-item + .list-item {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1px solid #eef2f7;
}

.seat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.seat {
  text-align: center;
  border-radius: 12rpx;
  padding: 14rpx 0;
  font-size: 24rpx;
}

.seat.free {
  background: #ecfdf3;
  color: #15803d;
}

.seat.occupied {
  background: #fee2e2;
  color: #b91c1c;
}

.seat.mine {
  background: #dbeafe;
  color: #1d4ed8;
}
