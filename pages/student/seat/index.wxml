<navigation-bar title="学生端 · 座位选择" back="{{true}}" color="#111827" background="#f5f7fb"></navigation-bar>
<view class="scroll-page">
  <scroll-view class="scroll-area" scroll-y="true" type="list">
    <view wx:if="{{allowed}}" class="card">
      <view class="section-title">{{busName}} 座位图</view>
      <view class="muted" style="margin-bottom: 14rpx;">绿色可选，红色已占，蓝色为我</view>
      <view class="seat-grid">
        <view
          wx:for="{{seats}}"
          wx:key="seatNo"
          class="seat {{item.status === 'mine' ? 'mine' : item.status === 'occupied' ? 'occupied' : 'free'}}"
          bindtap="chooseSeat"
          data-seat="{{item.seatNo}}"
        >
          {{item.seatNo}}
        </view>
      </view>
    </view>
  </scroll-view>
</view>
