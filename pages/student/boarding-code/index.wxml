<navigation-bar title="当前乘车码" back="{{true}}" color="#111827" background="#f5f7fb"></navigation-bar>
<view class="scroll-page">
  <scroll-view class="scroll-area" scroll-y="true" type="list">
    <view class="card" style="background: linear-gradient(130deg, #eff6ff, #ecfeff);">
      <view class="section-title">请向司机出示乘车码</view>
      <view class="muted">当前乘车段：第{{segmentIndex}}段 · {{lineName}}</view>
      <view class="muted" style="margin-top: 8rpx;">{{startStation}} → {{endStation}}</view>
    </view>

    <view class="card qrcode-card">
      <canvas type="2d" id="boardingQrcode" class="qrcode-canvas"></canvas>
      <view wx:if="{{qrError}}" class="qr-error">{{qrError}}</view>
      <view wx:if="{{codeText}}" class="code-token">{{codeText}}</view>
      <view class="muted" style="margin-top: 16rpx;">生成时间：{{issuedAtText}}</view>
      <button class="primary-btn" style="width: 100%; margin-top: 18rpx;" bindtap="refreshCode">刷新乘车码</button>
    </view>
  </scroll-view>
</view>
