<navigation-bar title="行程监控" back="{{true}}" color="#111827" background="#f5f7fb"></navigation-bar>
<view class="scroll-page journey-page">
  <scroll-view class="scroll-area" scroll-y="true" type="list">
    <view class="card">
      <view class="row" style="margin-bottom: 12rpx;">
        <view>
          <view class="section-title" style="margin-bottom: 8rpx;">{{lineName || '多线路换乘'}}</view>
          <view class="muted">{{startStation}} → {{endStation}}</view>
        </view>
        <text class="badge">{{status}}</text>
      </view>
      <view class="muted">当前站点：{{timelineStops[activeIndex].name || startStation}}</view>
      <view class="muted" style="margin-top: 8rpx;">当前乘车段：第{{currentSegmentIndex + 1}}段 · {{currentSegmentName}}</view>
      <view class="muted" style="margin-top: 8rpx;">本段路线：{{currentSegmentStart}} → {{currentSegmentEnd}}</view>
      <view wx:if="{{currentSegmentDirection}}" class="muted" style="margin-top: 8rpx;">当前方向：{{currentSegmentDirection === 'forward' ? '正向' : '返向'}}</view>
      <view wx:if="{{currentBusName}}" class="muted" style="margin-top: 8rpx;">已绑定车辆：{{currentBusName}}</view>
      <view wx:if="{{currentBusStation}}" class="muted" style="margin-top: 8rpx;">车辆当前站点：{{currentBusStation}}</view>
      <view wx:if="{{transferStations.length}}" class="muted" style="margin-top: 8rpx;">换乘站：{{transferStations.join(' / ')}}</view>
    </view>

    <view class="card" wx:if="{{rideStatusKey === 'pending_boarding'}}">
      <view class="section-title">待上车</view>
      <view wx:if="{{waitingBusArrived}}" class="muted">车辆已到达，请尽快扫码乘车。</view>
      <view wx:elif="{{waitingBusName}}" class="muted">距离当前站点最近的车为 {{waitingBusName}}，还有 {{waitingBusStops}} 站到达，请等待。</view>
      <view wx:else class="muted">正在等待当前线路与方向匹配的车辆，请稍候。</view>
      <button class="primary-btn" style="width: 100%; margin-top: 18rpx;" bindtap="showBoardingCode">打开乘车码</button>
    </view>

    <view class="card" wx:if="{{rideStatusKey === 'on_bus'}}">
      <view class="section-title">乘车中</view>
      <view class="list-item row"><text>当前车辆</text><text class="muted">{{currentBusName}}</text></view>
      <view class="list-item row"><text>下一站</text><text class="muted">{{timelineStops[activeIndex + 1].name || currentSegmentEnd}}</text></view>
      <view class="list-item row"><text>到站动作</text><text class="muted">到达本段终点后自动下车</text></view>
      <button class="primary-btn" style="width: 100%; margin-top: 18rpx;" bindtap="goSeat">选择座位</button>
    </view>

    <view class="card" wx:if="{{rideStatusKey === 'finished'}}">
      <view class="section-title">行程完成</view>
      <view class="muted">你已到达终点站，本次乘车流程结束。</view>
    </view>

    <view class="card route-panel">
      <scroll-view class="route-scroll" scroll-y="true">
        <view class="route-track" style="height: {{timelineHeight}}rpx;">
          <view class="bus-indicator" style="top: {{busTop}}rpx;">🚌</view>
          <block wx:for="{{timelineStops}}" wx:key="index" wx:for-item="stop" wx:for-index="index">
            <view class="route-stop" style="height: {{ROW_HEIGHT || 104}}rpx;">
              <view class="route-rail">
                <view wx:if="{{index > 0}}" class="rail-top" style="background: {{timelineStops[index - 1].connectorColor}};"></view>
                <view class="stop-dot" style="background: {{stop.color}};"></view>
                <view wx:if="{{index < timelineStops.length - 1}}" class="rail-bottom" style="background: {{stop.connectorColor}};"></view>
              </view>
              <view class="route-content">
                <view class="route-stop-name">{{stop.name}}</view>
                <view class="route-stop-meta">
                  <text wx:if="{{index === activeIndex}}" class="active-tag">当前站</text>
                  <text wx:elif="{{stop.isStart}}">起点</text>
                  <text wx:elif="{{stop.isEnd}}">终点</text>
                  <text wx:elif="{{stop.isTransfer}}" class="transfer-tag">换乘站</text>
                  <text wx:else>途径站</text>
                </view>
              </view>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>

    <view class="tabs" style="grid-template-columns: repeat(2, 1fr);">
      <view class="tab-item" bindtap="endRide"><view class="tab-title">退出行程</view><view class="muted">结束当前行程绑定</view></view>
      <view class="tab-item" bindtap="backHome"><view class="tab-title">返回首页</view><view class="muted">返回学生端首页</view></view>
    </view>
  </scroll-view>
</view>
