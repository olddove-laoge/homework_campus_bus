<navigation-bar title="学生端 · 站点 ETA" back="{{true}}" color="#111827" background="#f5f7fb"></navigation-bar>
<view class="scroll-page">
  <scroll-view class="scroll-area" scroll-y="true" type="list">
    <view class="card">
      <view class="section-title">当前站点</view>
      <view class="row">
        <view>
          <view style="font-size: 30rpx; font-weight: 600;">{{currentStationName}}</view>
          <view class="muted">下一辆：{{nextBusName}}</view>
        </view>
        <text class="badge">{{nextBusEta}}</text>
      </view>
    </view>

    <view class="card">
      <view class="section-title">未来班次</view>
      <block wx:if="{{upcomingBuses.length}}">
        <block wx:for="{{upcomingBuses}}" wx:key="id">
          <view class="list-item row"><text>{{item.name}}</text><text class="muted">{{item.eta}}</text></view>
        </block>
      </block>
      <view wx:else class="muted">暂无更多班次信息</view>
    </view>
  </scroll-view>
</view>